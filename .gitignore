.cloudflared/

# --- Node / Next.js build artifacts ---
node_modules/
**/node_modules/
.next/
**/.next/
.turbo/
**/.turbo/
*.tsbuildinfo
coverage/

# --- macOS / editor ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Logs & temp ---
*.log
*.pid
*.tmp
