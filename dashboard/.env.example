# --- Required: where the Radicle HTTP daemon is reachable ---
RADICLE_HTTP_BASE=http://127.0.0.1:8090

# Optional: text shown in profile/node footers instead of raw RADICLE_HTTP_BASE.
# Use when RADICLE_HTTP_BASE is loopback (default) so visitors don’t see 127.0.0.1,
# or set to a public API URL/label if you expose radicle-httpd on a hostname.
# NEXT_PUBLIC_RADICLE_HTTP_LABEL=https://api.example.com

# --- Site mode ---
# personal  -> "/" redirects to "/profile"; marketing chrome hidden
# marketing -> keeps the landing page at "/", profile shown as live demo
SITE_MODE=marketing

# --- Optional: which repos the curated /profile page should list ---
# Comma-separated. If unset, defaults from src/lib/profileRepos.ts are used.
# RADICLE_REPO_IDS=rad:zAbCd...,rad:zEfGh...,rad:zIjKl...

# --- Optional: hostname shown in Explorer links ---
# NEXT_PUBLIC_RADICLE_EXPLORER_NODE=rosa.radicle.xyz

# --- Optional: profile header (used in personal mode) ---
# RADICLE_PROFILE_ALIAS=your_alias
# RADICLE_DELEGATE_DID=did:key:z6Mk...
# RADICLE_PROFILE_BIO=Builder, occasional writer. Lives in the terminal.

# Avatar image (https, data:, or a path under /public).
# Leave unset to use the auto-generated gradient + monogram.
# RADICLE_PROFILE_AVATAR_URL=/avatar.jpg

# Social / contact links shown as chips in the hero.
# Format: "label:url, label:url".  Common labels: site, email, x, mastodon, bsky, github.
# Use the URL scheme for non-http things (mailto:, https://, etc).
# RADICLE_PROFILE_LINKS=site:https://example.com, email:mailto:you@example.com, x:https://x.com/you

# --- Optional: footer "Source" link ---
# Set to your published Radicle Explorer URL (or a GitHub mirror) so the
# footer "Source" link points to your code instead of radicle.xyz.
# NEXT_PUBLIC_SOURCE_URL=https://radicle.network/nodes/rosa.radicle.xyz/rad%3A...
