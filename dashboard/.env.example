# --- Required: where the Radicle HTTP daemon is reachable ---
RADICLE_HTTP_BASE=http://127.0.0.1:8090

# Optional: text shown in profile/node footers instead of raw RADICLE_HTTP_BASE.
# Use when RADICLE_HTTP_BASE is loopback (default) so visitors don’t see 127.0.0.1,
# or set to a public API URL/label if you expose radicle-httpd on a hostname.
# NEXT_PUBLIC_RADICLE_HTTP_LABEL=https://api.example.com

# --- Site mode ---
# personal -> "/" redirects to "/profile" (default)
SITE_MODE=personal

# --- Optional: which repos the curated /profile page should list ---
# Comma-separated. If unset, defaults from src/lib/profileRepos.ts are used.
# RADICLE_REPO_IDS=rad:zAbCd...,rad:zEfGh...,rad:zIjKl...

# Activity export only (`npm run export-activity`): which RIDs to scan for commits.
# If unset, export uses RADICLE_REPO_IDS. Set to `all` or `*` (alone) to use every repo
# on the node (`GET /api/v1/repos?show=all`) so new projects appear without editing the list.
# Do not set RADICLE_REPO_IDS=all (it would break /profile).
# RADICLE_ACTIVITY_EXPORT_REPO_IDS=all

# --- Optional: Radicle Explorer links (Recent activity, Repo cards, etc.) ---
# Explorer loads repo data from the NODE in the URL. If that seed does not
# replicate your RID yet, the Explorer tab can show "NetworkError when
# attempting to fetch resource". Set NODE to a public seed that has your repo.
# Default in code is iris.radicle.xyz (same seed `rad push` links use on radicle.network).
# NEXT_PUBLIC_RADICLE_EXPLORER_ORIGIN=https://radicle.network
# NEXT_PUBLIC_RADICLE_EXPLORER_NODE=iris.radicle.xyz

# --- Optional: profile header (used in personal mode) ---
# RADICLE_PROFILE_ALIAS=your_alias
# RADICLE_DELEGATE_DID=did:key:z6Mk...
# RADICLE_PROFILE_BIO=Builder, occasional writer. Lives in the terminal.

# Avatar image (https, data:, or a path under /public).
# Leave unset to use the auto-generated gradient + monogram.
# RADICLE_PROFILE_AVATAR_URL=/avatar.jpg

# Social / contact links shown as chips in the hero.
# Format: "label:url, label:url".  Common labels: site, email, x, mastodon, bsky, github.
# Use the URL scheme for non-http things (mailto:, https://, etc).
# RADICLE_PROFILE_LINKS=site:https://example.com, email:mailto:you@example.com, x:https://x.com/you

# Optional: heatmap + recent activity from a JSON file (see README "Activity snapshot").
# Repo cards still use RADICLE_HTTP_BASE. Path relative to dashboard/ cwd or absolute.
# RADICLE_ACTIVITY_SNAPSHOT_PATH=data/activity-snapshot.json

# Optional: how far back /profile activity pulls from httpd (and export-activity). Default ~3y.
# Clamped 30–3650. Pagination cap separate (below).
# RADICLE_ACTIVITY_HISTORY_DAYS=1095

# Optional: max /commits?page= requests per repo (5 commits max per page). Default 3000 (~15k commits).
# Clamped 1–20000.
# RADICLE_ACTIVITY_MAX_COMMIT_PAGES=3000

# Optional: walk commit parents from meta.head (fills gaps vs paginated /commits). Default 8000; 0=off.
# RADICLE_ACTIVITY_ANCESTRY_MAX_COMMITS=8000

# --- Optional: footer "Source" link (override for forks) ---
# Full repo URL on Explorer — no /tree/... segment required. `rad%3A...` is the
# same RID as `rad:...` (encoded colon). Do not paste placeholder "..."; use the
# full id from `rad push`, Explorer, or `rad inspect` / your RID list.
# Default in SiteFooter matches rad push canonical (iris.radicle.xyz + full RID).
# NEXT_PUBLIC_SOURCE_URL=https://radicle.network/nodes/iris.radicle.xyz/rad:z2v11Gpk44QqZ7zy8W9fva8wXXDBi
